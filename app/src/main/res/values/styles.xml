<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- SearchBar and SearchView -->
    <style name="Custom.Searchbar" parent="Widget.Material3.SearchBar">
        <item name="backgroundTint">@color/white_primary</item>
        <item name="hintTextColor">@color/black</item>
        <item name="shapeAppearanceOverlay">@style/Custom.SearchBar.Shape</item>
        <item name="android:textAppearance">@style/Custom.SearchBar.TextAppearance</item>
    </style>
    <style name="Custom.SearchBar.Shape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>
    <style name="Custom.SearchBar.TextAppearance" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/gray_mid</item>
    </style>

    <style name="Custom.SearchView" parent="Widget.Material3.SearchView">
        <item name="backgroundTint">@color/black</item>
    </style>

</resources>