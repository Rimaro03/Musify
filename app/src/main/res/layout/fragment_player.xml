<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.player.PlayerFragment"
    android:fitsSystemWindows="true"
    android:layout_margin="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/player_track_cover_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <ImageView
            android:id="@+id/player_track_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="@string/track_cover" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Title and buttons -->
    <LinearLayout
        android:id="@+id/player_track_title_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/player_track_cover_container">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/player_track_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Inside Out"
                android:textStyle="bold"
                android:textSize="@dimen/player_track_title_size"/>

            <TextView
                android:id="@+id/player_track_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="5dp"
                android:textColor="@color/gray_light"
                android:text="The Chainsmokers, The Chainsmokers, The"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_track_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                app:icon="@drawable/media3_icon_heart_unfilled"
                android:contentDescription="@string/play_pause_icon"
                app:iconSize="25dp"
                style="@style/Widget.Material3.Button.IconButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_track_download"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                app:icon="@drawable/download_24px"
                android:contentDescription="@string/play_pause_icon"
                app:iconSize="25dp"
                style="@style/Widget.Material3.Button.IconButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_track_share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                app:icon="@drawable/share_24px"
                android:contentDescription="@string/play_pause_icon"
                app:iconSize="25dp"
                style="@style/Widget.Material3.Button.IconButton"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Progress bar -->
    <LinearLayout
        android:id="@+id/player_track_seekbar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/player_track_title_container"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatSeekBar
            android:id="@+id/player_track_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:layout_marginTop="5dp">

            <TextView
                android:id="@+id/player_track_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_light"
                android:text="0:00" />

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/player_track_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_light"
                android:text="0:00" />

        </LinearLayout>

    </LinearLayout>

    <!-- Playback controls -->
    <LinearLayout
        android:id="@+id/player_track_playback_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/player_track_seekbar_container">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/player_shuffle_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            app:icon="@drawable/media3_icon_shuffle_on"
            android:contentDescription="@string/play_pause_icon"
            app:iconSize="@dimen/player_skip_icon"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/player_skip_prev_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            app:icon="@drawable/media3_icon_previous"
            android:contentDescription="@string/play_pause_icon"
            app:iconSize="@dimen/player_skip_icon"
            style="@style/Widget.Material3.Button.IconButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/player_play_btn"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:icon="@drawable/play_arrow_24px"
            app:cornerRadius="100dp"
            app:backgroundTint="@android:color/white"
            app:iconTint="@android:color/black"
            app:rippleColor="@android:color/darker_gray"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconGravity="textTop"
            app:iconSize="40dp"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/player_skip_next_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            app:icon="@drawable/media3_icon_next"
            android:contentDescription="@string/play_pause_icon"
            app:iconSize="@dimen/player_skip_icon"
            style="@style/Widget.Material3.Button.IconButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/player_repeat_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            app:icon="@drawable/media3_icon_repeat_one"
            android:contentDescription="@string/play_pause_icon"
            app:iconSize="@dimen/player_skip_icon"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>