<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    android:id="@+id/miniplayerCard"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:paddingHorizontal="10dp"
    android:layout_gravity="center_vertical"
    app:cardBackgroundColor="?attr/colorSurfaceVariant">

    <ImageView
        android:id="@+id/miniplayer_track_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="10dp"
        android:contentDescription="@string/track_thumbnail"
        android:src="@drawable/ic_launcher_foreground"
        android:background="@drawable/rounded_track_bg"
        android:clipToOutline="true"
        android:layout_gravity="center_vertical"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="10dp"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/miniplayer_track_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="End of Beginning"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/miniplayer_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Djo"
            android:textColor="@color/gray_light"
            android:textSize="16sp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/miniplayer_like"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            app:icon="@drawable/favorite_24px"
            android:contentDescription="@string/menu_icon"
            app:iconSize="25dp"
            style="@style/Widget.Material3.Button.IconButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/miniplayer_play_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            app:icon="@drawable/play_arrow_24px"
            android:contentDescription="@string/play_pause_icon"
            app:iconSize="25dp"
            style="@style/Widget.Material3.Button.IconButton"/>

    </LinearLayout>

</LinearLayout>

